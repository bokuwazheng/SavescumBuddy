<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
                    xmlns:converters="clr-namespace:SavescumBuddy.CustomControls.Converters;assembly=SavescumBuddy.CustomControls">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Styles.xaml" Source="{ThemeDictionary }"/>
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="DefaultButtonStyle2" TargetType="Button">
        <Setter Property="BorderBrush" Value="Blue"/>
    </Style>

</ResourceDictionary>